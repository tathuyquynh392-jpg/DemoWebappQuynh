@model IEnumerable<DemoWebapp.Models.Room>
@{
    ViewData["Title"] = "Quản lý phòng";
}



<p style="margin-top:10px;">
    <!-- Nút Thêm phòng -->
    <a class="btn" asp-action="Create"
       style="background-color:#5a341f; color:white; font-size:18px;
              padding:10px 20px; text-decoration:none; border-radius:8px;">
        <i class="fas fa-plus"></i> Thêm phòng
    </a>
</p>

<div class="card-container">
    @foreach (var room in Model)
    {
        <div class="card">
            <h2>@room.TenPhong</h2>
            <p>Giá: @room.Gia.ToString("C")</p>
            <p>Trạng thái: <strong>@room.TrangThai</strong></p>
            <p>
                <!-- Nút Sửa -->
                <a class="btn" asp-action="Edit" asp-route-id="@room.RoomId"
                   style="background-color:#a67c52; color:white; font-size:10px;
                              padding:8px 14px; text-decoration:none; border-radius:6px; margin-right:5px;">
                    <i class="fas fa-edit"></i> Sửa
                </a>

                <!-- Nút Xóa -->
                <a class="btn" asp-action="Delete" asp-route-id="@room.RoomId"
                   style="background-color:#c94c3d; color:white; font-size:10px;
                              padding:8px 14px; text-decoration:none; border-radius:6px; margin-right:5px;">
                    <i class="fas fa-trash"></i> Xóa
                </a>

                <!-- Nút Chi tiết -->
                <a class="btn" asp-action="Details" asp-route-id="@room.RoomId"
                   style="background-color:#8c5e3c; color:white; font-size:10px;
                              padding:8px 14px; text-decoration:none; border-radius:6px;">
                    <i class="fas fa-info-circle"></i> Chi tiết
                </a>
            </p>
        </div>
    }
    </div>