@model DemoWebapp.Models.Room
@{
    ViewData["Title"] = "Chi tiết phòng";
}


<div style="max-width:400px; background-color:#f6e3d6; padding:20px; border-radius:12px; box-shadow:0 6px 12px rgba(0,0,0,0.1);">
    <h2 style="margin-bottom:10px;">@Model.TenPhong</h2>
    <p>Giá: @Model.Gia.ToString("C")</p>
    <p>Trạng thái: @Model.TrangThai</p>
</div>

<br />
<a asp-action="Index" class="btn btn-secondary" style="background-color:#7b4d30; border:none; color:white;">
    <i class="fas fa-arrow-left"></i> Quay lại
</a>