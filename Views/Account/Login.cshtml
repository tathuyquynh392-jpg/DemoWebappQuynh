@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Đăng nhập hệ thống</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #5a3e2b, #c8a27c);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: Arial;
        }

        .login-box {
            width: 360px;
            background: #fff8f0;
            padding: 35px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .login-box h2 {
            text-align: center;
            margin-bottom: 25px;
            color: #5a3e2b;
            font-weight: bold;
        }

        .form-control {
            margin-bottom: 15px;
            border-radius: 8px;
        }

        .form-control:focus {
            border-color: #a67c52;
            box-shadow: 0 0 5px rgba(166,124,82,0.5);
        }

        .btn-login {
            width: 100%;
            background: #8b5e3c;
            border: none;
            border-radius: 8px;
        }

        .btn-login:hover {
            background: #6f4a2f;
        }

        .error {
            color: red;
            text-align: center;
            margin-top: 10px;
        }

        .logo {
            text-align: center;
            font-size: 40px;
            margin-bottom: 10px;
        }
    </style>
</head>

<body>

    <div class="login-box">

        <div class="logo">🏠</div>

        <h2>Quản lý nhà trọ</h2>

        <form asp-action="Login" method="post">

            <input name="username"
                   class="form-control"
                   placeholder="Tài khoản" required />

            <input name="password"
                   type="password"
                   class="form-control"
                   placeholder="Mật khẩu" required />

            <button type="submit" class="btn btn-login text-white">
                Đăng nhập
            </button>
        </form>

        @if (ViewBag.Error != null)
        {
            <p class="error">@ViewBag.Error</p>
        }

    </div>

</body>
</html>
